# Copy to .env (or source manually) before running DeployPoolINFT.s.sol.
# .env is gitignored; .env.example is committed.

# Admin EOA — owns the contract. Funded with Galileo testnet OG.
DEPLOYER_PRIVATE_KEY=0x_your_admin_private_key

# Orchestrator TEE signer address. In dev, derive via `cast wallet address $TEE_SIGNER_PRIVATE_KEY`.
TEE_ORACLE_ADDRESS=0x_your_oracle_address

# Optional — for `--verify` against 0G Galileo Chainscan.
CHAINSCAN_API_KEY=
