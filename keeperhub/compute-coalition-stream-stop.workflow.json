{
  "name": "compute-coalition-stream-stop",
  "description": "Stop a Superfluid GDA distribution flow into a coalition pool (rate=0) and call back to the orchestrator.",
  "enabled": true,
  "nodes": [
    {
      "id": "trigger",
      "type": "trigger",
      "position": {"x": 100, "y": 200},
      "data": {
        "type": "trigger",
        "label": "Trigger",
        "config": {
          "triggerType": "Manual",
          "inputs": {
            "session_id": {"type": "string"},
            "super_token": {"type": "string"},
            "pool_address": {"type": "string"},
            "sender": {"type": "string"},
            "callback_url": {"type": "string"}
          }
        }
      }
    },
    {
      "id": "stop-flow",
      "type": "action",
      "position": {"x": 400, "y": 200},
      "data": {
        "type": "action",
        "label": "GDA distributeFlow rate=0",
        "config": {
          "actionType": "web3/write-contract",
          "integrationId": "05u5ggiksbjjuxvru76hb",
          "network": "16602",
          "contractAddress": "0xfDF1C52BBe39884Bd9fDF2407903ff3a91a25B17",
          "abiFunction": "distributeFlow",
          "abi": "[{\"name\":\"distributeFlow\",\"type\":\"function\",\"stateMutability\":\"nonpayable\",\"inputs\":[{\"name\":\"token\",\"type\":\"address\"},{\"name\":\"from\",\"type\":\"address\"},{\"name\":\"pool\",\"type\":\"address\"},{\"name\":\"requestedFlowRate\",\"type\":\"int96\"},{\"name\":\"userData\",\"type\":\"bytes\"}],\"outputs\":[{\"type\":\"bool\"}]}]",
          "functionArgs": "[\"{{@trigger:Trigger.data.super_token}}\",\"{{@trigger:Trigger.data.sender}}\",\"{{@trigger:Trigger.data.pool_address}}\",\"0\",\"0x\"]",
          "gasLimitMultiplier": "1.2"
        }
      }
    },
    {
      "id": "callback",
      "type": "action",
      "position": {"x": 700, "y": 200},
      "data": {
        "type": "action",
        "label": "POST stream_stopped",
        "config": {
          "actionType": "HTTP Request",
          "httpMethod": "POST",
          "endpoint": "{{@trigger:Trigger.data.callback_url}}",
          "httpHeaders": "{\"Content-Type\":\"application/json\"}",
          "httpBody": "{\"event\":\"stream_stopped\",\"session_id\":\"{{@trigger:Trigger.data.session_id}}\",\"tx_hash\":\"{{@stop-flow:GDA distributeFlow rate=0.transactionHash}}\"}"
        }
      }
    }
  ],
  "edges": [
    {"id": "e1", "source": "trigger", "target": "stop-flow"},
    {"id": "e2", "source": "stop-flow", "target": "callback"}
  ]
}
